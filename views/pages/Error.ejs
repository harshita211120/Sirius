<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error</title>
    <style>
    :root {
        --dark: #000000;
        --primary: #B3005E;
        --accent: #E90064;
        --soft: #FF5F9E;
        --input-bg: #6b6fae;
    }

    body {
        background: radial-gradient(circle at center, #000000 0%, #000000 70%);
        font-family: 'DM Sans', Arial, sans-serif;
        color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
    }

    .error-box {
        background: #000000;
        padding: 50px;
        width: 100%;
        max-width: 650px;
        border-radius: 25px;
        text-align: center;
    }

    h1.status-code {
        color: var(--soft);
        font-size: 90px;
        margin: 0;
        font-weight: 800;
        letter-spacing: 3px;
    }

    h2.message {
        color: white;
        font-size: 26px;
        margin-top: 15px;
        margin-bottom: 20px;
    }

    p.description {
        color: rgba(255,255,255,0.7);
        margin-bottom: 35px;
        line-height: 1.6;
        font-size: 15px;
    }

    .btn-home {
        background: linear-gradient(90deg, var(--primary), var(--accent));
        border: none;
        padding: 14px 35px;
        border-radius: 12px;
        color: white;
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        box-shadow: 0 8px 25px #B3005E;
    }

    .btn-home:hover {
        background: linear-gradient(90deg, var(--accent), var(--soft));
        transform: translateY(-3px);
    }

    .stack-trace {
        margin-top: 40px;
        text-align: left;
        background: var(--input-bg);
        padding: 18px;
        border-radius: 15px;
        border: 2px solid var(--accent);
        font-family: monospace;
        font-size: 13px;
        color: white;
        overflow-x: auto;
    }

    pre {
        margin: 0;
    }
</style>
</head>

<body>

    <div class="error-box">
        <h1 class="status-code">
            <%= (typeof error !=='undefined' && error.status) ? error.status : 'Oops!' %>
        </h1>

        <h2 class="message">
            <%= (typeof message !=='undefined' && message) ? message : 'Something went wrong.' %>
        </h2>

        <p class="description">
            We're sorry, but the page you are looking for might have been removed, had its name changed, or is
            temporarily unavailable.
        </p>

        <a href="/" class="btn-home">Return to Home</a>

        <% if (typeof error !=='undefined' && error.stack && error.stack.length> 0) { %>
            <div class="stack-trace">
                <pre><%= error.stack %></pre>
            </div>
            <% } %>
    </div>

</body>

</html>